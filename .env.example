NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=https://your-domain.example

# Meta WhatsApp Cloud API
WHATSAPP_PROVIDER=meta
WHATSAPP_VERIFY_TOKEN=replace-with-a-random-verify-token
WHATSAPP_ACCESS_TOKEN=EAAG...
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_GRAPH_VERSION=v21.0

# GreenAPI alternative WhatsApp provider
GREEN_API_URL=https://api.green-api.com
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=
GREEN_API_WEBHOOK_TOKEN=

# Persistent state storage
# Render disk example: STATE_DIR=/var/data
STATE_DIR=.data
STATE_FILE=

# OpenAI / ChatGPT
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
WHATSAPP_DRY_RUN=false
TEST_WHATSAPP_TO=27821234567

# Admin approvals
ADMIN_WHATSAPP_NUMBER=27820000000
ADMIN_WEBHOOK_URL=
ADMIN_APPROVAL_SECRET=replace-with-a-long-secret

# Booking and payments
CALENDAR_PROVIDER=manual
PAYMENT_BANK_NAME=Your Bank
PAYMENT_ACCOUNT_NAME=Your Business Name
PAYMENT_ACCOUNT_NUMBER=0000000000
PAYMENT_BRANCH_CODE=000000
PAYMENT_REFERENCE_PREFIX=CLN
PAYMENT_LINK_BASE_URL=

# Quote defaults
QUOTE_CURRENCY=ZAR
QUOTE_VALID_HOURS=48
